{
  "name": "power-panel",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "web": "bun --cwd apps/web dev",
    "web:build": "bun --cwd apps/web build",
    "web:start": "bun --cwd apps/web start",
    "worker": "bun --cwd apps/worker start",
    "db:generate": "bun --cwd packages/db generate",
    "install:all": "bun install",
    "web:prod": "bun run db:generate && bun run web:build && bun run web:start",
    "worker:prod": "bun run db:generate && bun run worker"
  },
  "dependencies": {
    "@types/bun": "^1.3.8"
  }
}
